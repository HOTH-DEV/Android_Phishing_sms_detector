<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Read recent SMS (granted only on explicit user consent). -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <!-- Receive incoming SMS for real-time analysis (bonus feature). -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <!-- Post a warning notification when a risky SMS is detected. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- NOTE: no INTERNET permission is requested on purpose: the app does
         all inference locally and must not send any message off-device. -->

    <application
        android:name=".PhishingApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PhishingDetector">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PhishingDetector">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Allow "Share to" this app from any other app to analyse text/URL. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- Real-time SMS analysis on reception. -->
        <receiver
            android:name=".sms.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
